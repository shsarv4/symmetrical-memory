{
  "hosting": {
    "public": "frontend/build",
    "site": "swatisarc",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "backend"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "backend",
    "runtime": "nodejs18"
  },
  "firestore": {
    "indexes": "firestore.indexes.json"
  }
}
